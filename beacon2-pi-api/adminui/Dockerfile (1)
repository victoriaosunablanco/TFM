#esto lo he añadido
ENV CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# Copiar la clave GPG al contenedor
COPY nodesource-repo.gpg.key .

# Agregar repositorio de Node.js y hacer la instalación
#Descargar del https de arriba el .gpg.key y añadirlo a esta carpeta, es el archivo que esta entre < > 
RUN mkdir -p /etc/apt/keyrings && \
    gpg --dearmor < nodesource-repo.gpg.key > /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_$NODE_MAJOR.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && apt-get install -y nodejs

