FROM node:20


# Configura proxy para npm (sin usar ENV globales)
RUN npm config set proxy http://USUARIO:CONTRASEÑA! && \
    npm config set https-proxy http://USUARIO:CONTRASEÑA && \
    npm config set strict-ssl false && \
    npm config set registry https://registry.npmjs.org/ && \
    npm install

# Copia el resto del proyecto
COPY . .

RUN pip install -r requirements.txt && npm run tailwind:build && python manage.py collectstatic --noinput

FROM python:3.10-bullseye

RUN apt-get update && apt-get upgrade -y && apt-get clean

RUN mkdir -p /home/app

RUN addgroup --system app && adduser --system --group app

ENV HOME=/home/app
ENV APP_HOME=/home/app/web
RUN mkdir $APP_HOME
WORKDIR $APP_HOME

ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1
ENV ENVIRONMENT prod
ENV TESTING 0
ENV PYTHONPATH $APP_HOME

COPY --from=builder /usr/src/app/wheels /wheels
COPY --from=builder /usr/src/app/requirements.txt .
COPY --from=builder /usr/src/app/media $APP_HOME/media
RUN pip install --upgrade pip
RUN pip install --no-cache /wheels/*

COPY . $APP_HOME

RUN chown -R app:app $HOME

USER app
